/*O seu primeiro programa em qualquer linguagem de programação normalmente é o "Hello World!". Neste primeiro problema tudo o que você precisa fazer é imprimir esta mensagem na tela.*/

#include <iostream> // biblioteca padrão de entrada e saída

using namespace std; //Evita ter que digitar std:: antes de cada comando da biblioteca padrão.

int main(){ // A função principal onde a execução começa.

    cout << "Hello World!" << endl; // cout = imprimir na tela / endl = quebra de linha
}